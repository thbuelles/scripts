<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.bici.openclaw-gateway-watchdog</string>
    <key>UserName</key>
    <string>bici</string>
    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>/Users/bici/.openclaw/workspace/tools/openclaw_gateway_watchdog.sh</string>
    </array>
    <key>StartInterval</key>
    <integer>60</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>WorkingDirectory</key>
    <string>/Users/bici/.openclaw/workspace</string>
    <key>StandardOutPath</key>
    <string>/Users/bici/.openclaw/workspace/logs/openclaw-watchdog.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/bici/.openclaw/workspace/logs/openclaw-watchdog.stderr.log</string>
  </dict>
</plist>
